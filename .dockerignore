# ================================================================================
# DOCKER IGNORE - RESTAURANT VOICE SYSTEM
# ================================================================================
# Archivos y directorios que no deben incluirse en el contexto de build de Docker
# ================================================================================

# Git
.git
.gitignore

# Documentation
*.md
docs/
LICENSE

# IDE
.vscode/
.idea/
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
ENV/
.eggs/
*.egg-info/
.mypy_cache/
.pytest_cache/
.coverage
htmlcov/
.tox/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build artifacts
dist/
build/
*.egg

# Environment files (las variables se pasan via docker-compose)
.env
.env.*
!.env.example

# Logs
logs/
*.log

# Temporary files
temp/
tmp/
*.tmp

# OS files
.DS_Store
Thumbs.db

# Tests
tests/
test/
*_test.py
test_*.py

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Scripts (no needed in containers)
scripts/
*.bat
*.sh

# Coverage reports
coverage/
.nyc_output/
