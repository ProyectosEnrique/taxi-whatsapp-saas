# ============================================================================
# CONFIGURACIÓN PARA DEMO INTERACTIVA
# ============================================================================
# Copia este archivo a .env y completa con tus valores reales

# ----------------------------------------------------------------------------
# TWILIO (REQUERIDO)
# ----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+5255XXXXXXXX
WHATSAPP_PROVIDER=twilio

# ----------------------------------------------------------------------------
# CLOUDFLARE TUNNEL (REQUERIDO)
# ----------------------------------------------------------------------------
# URL pública donde estará expuesto el servicio
BASE_URL=https://demo.tudominio.com

# Token del tunnel de Cloudflare
# Obtenerlo en: https://dash.cloudflare.com (Tunnel > Configure > Install connector)
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoixxxxxxxxxxxxx

# ----------------------------------------------------------------------------
# PAGOS (OPCIONAL - Dejar vacío para solo efectivo)
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
MERCADOPAGO_ACCESS_TOKEN=

# ----------------------------------------------------------------------------
# STT (OPCIONAL - Para notas de voz)
# ----------------------------------------------------------------------------
DEEPGRAM_API_KEY=

# ----------------------------------------------------------------------------
# ADMIN (OPCIONAL)
# ----------------------------------------------------------------------------
WHATSAPP_ADMIN_NUMBERS=+5215512345678

# ----------------------------------------------------------------------------
# NO MODIFICAR (URLs internas de Docker)
# ----------------------------------------------------------------------------
CUSTOMER_APP_URL=http://customer-app:80
MENU_SERVICE_URL=http://api-service:5011
