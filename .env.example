# ==============================================================================
# TAXI WHATSAPP SAAS — Variables de entorno VPS
# cp .env.example .env  y completa los valores reales
# ==============================================================================

# ── LLM (al menos GROQ_API_KEY es obligatorio) ────────────────────────────────
# GROQ_API_KEY=
# CEREBRAS_API_KEY=
# GOOGLE_API_KEY=
# OPENAI_API_KEY=

# ── WhatsApp ──────────────────────────────────────────────────────────────────
# WHATSAPP_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# META_PHONE_NUMBER_ID=
# META_ACCESS_TOKEN=
# META_VERIFY_TOKEN=taxi_verify

# ── STT (opcional) ────────────────────────────────────────────────────────────
# DEEPGRAM_API_KEY=

# ── Seguridad — generar con: openssl rand -hex 32 ────────────────────────────
# JWT_SECRET=
# SESSION_SECRET_KEY=

# ── Modo LLM ──────────────────────────────────────────────────────────────────
# LLM_PROVIDER=groq
# LLM_FIRST_MODE=always

# ================================================================================
# (valores originales del proyecto — mantener para referencia)
# ================================================================================

# ============================================================================
# DATABASE
# ============================================================================
POSTGRES_DB=restaurant_db
POSTGRES_USER=restaurant
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION_min16chars

# Database connection string (auto-generated, don't modify)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32_CHANGE_IN_PRODUCTION

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Session Management
SESSION_SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32_CHANGE_IN_PRODUCTION
SESSION_EXPIRE_MINUTES=120

# ============================================================================
# VOICE ASSISTANT - AI APIs (ALL REQUIRED)
# ============================================================================

# -------------------------
# 1. DEEPGRAM (Speech-to-Text)
# -------------------------
# Get your key at: https://console.deepgram.com/
# Free tier: 45,000 minutes/month (~750 hours)
# Documentation: https://developers.deepgram.com/docs
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# -------------------------
# 2. GROQ (NLP/LLM)
# -------------------------
# Get your key at: https://console.groq.com/
# Free tier: Unlimited requests (rate limited)
# Documentation: https://console.groq.com/docs
GROQ_API_KEY=your_groq_api_key_here

# -------------------------
# 3. CARTESIA SONIC (Text-to-Speech) - NEW in v5.0 [RECOMMENDED]
# -------------------------
# ULTRA-FAST TTS: ~90ms latency (vs 200-1000ms de otros)
# Get your key at: https://play.cartesia.ai/ (Create account -> Settings)
# Free tier: Limited requests for testing
# Pricing: $0.015/1K characters (~$1.50 per 1000 responses)
# Documentation: https://docs.cartesia.ai/
CARTESIA_API_KEY=your_cartesia_api_key_here

# Cartesia Voice Configuration
# Browse voices at: https://play.cartesia.ai/ (Voice Library)
CARTESIA_VOICE_ID=846d6cb0-2301-48b6-9683-48f5618ea2f6

# Spanish Voice ID Options:
# ┌──────────────────────────────────────────┬────────────────────────────────┐
# │ Voice ID                                 │ Name & Characteristics         │
# ├──────────────────────────────────────────┼────────────────────────────────┤
# │ 846d6cb0-2301-48b6-9683-48f5618ea2f6    │ Spanish-speaking Lady (Default)│
# │ db832ebd-3cb6-42e7-9d47-912b425adbaa    │ Young Spanish-speaking Woman   │
# │ 2deb3edf-b9d8-4d06-8db9-5742fb8a3cb2    │ Spanish Narrator Lady          │
# │ 34dbb662-8e98-413c-a1ef-1a3407675fe7    │ Spanish-speaking Man           │
# │ a67e0421-22e0-4d5b-b586-bd4a64aee41d    │ Spanish Narrator Man           │
# │ 846fa30b-6e1a-49b9-b7df-6be47092a09a    │ Spanish Storyteller Man        │
# │ 2695b6b5-5543-4be1-96d9-3967fb5e7fec    │ Spanish Reporter Man           │
# └──────────────────────────────────────────┴────────────────────────────────┘

# Cartesia Model (latest is sonic-3)
CARTESIA_MODEL=sonic-3

# TTS Provider Selection
# Options: cartesia (fastest, recommended), piper (free local), gtts (fallback)
TTS_PROVIDER=cartesia

# -------------------------
# 4. ELEVENLABS (Text-to-Speech) - PREMIUM ALTERNATIVE
# -------------------------
# Get your key at: https://elevenlabs.io/app/settings/api-keys
# Free tier: 10,000 characters/month (~7 minutes of audio)
# Starter plan: $5/mo = 30,000 characters
# Documentation: https://elevenlabs.io/docs/api-reference/text-to-speech
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs Voice Configuration
# Browse voices at: https://elevenlabs.io/voice-library
# Or use API: https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Voice ID Options (Spanish voices recommended):
# ┌─────────────────┬──────────────────────┬─────────────────────────────────┐
# │ Voice ID        │ Name                 │ Characteristics                 │
# ├─────────────────┼──────────────────────┼─────────────────────────────────┤
# │ 21m00Tcm4TlvDq8 │ Rachel (Default)     │ Neutral, clear, professional    │
# │ EXAVITQu4vr4xnS │ Bella                │ Warm, friendly, conversational  │
# │ pNInz6obpgDQGcF │ Adam                 │ Deep, authoritative, confident  │
# │ onwK4e9ZLuTAKqW │ Daniel               │ Mature, informative, trustworthy│
# │ IKne3meq5aSn9Xn │ Serena               │ Soft, calming, pleasant         │
# └─────────────────┴──────────────────────┴─────────────────────────────────┘
# Note: For native Spanish, consider using ElevenLabs' multilingual voices
# with language parameter set to 'es' (see tts_handler.py)

# ElevenLabs Voice Settings
# Stability: 0.0-1.0 (lower=more expressive, higher=more stable)
# Similarity Boost: 0.0-1.0 (higher=closer to original voice)
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75

# Model Selection
# - eleven_multilingual_v2 (Recommended for Spanish)
# - eleven_turbo_v2 (Fastest, English only)
# - eleven_monolingual_v1 (Original, English only)
ELEVENLABS_MODEL=eleven_multilingual_v2

# ============================================================================
# NLP CONFIGURATION
# ============================================================================
# Groq Models (updated November 2024)
# Check current models at: https://console.groq.com/docs/models
#
# Available models:
# - llama-3.1-8b-instant       (Recommended: Fast, production-ready)
# - llama-3.3-70b-versatile    (More powerful, slower)
# - llama-3.2-90b-text-preview (Preview, not for production)
# - mixtral-8x7b-32768         (DEPRECATED - Do not use)
GROQ_MODEL=llama-3.1-8b-instant

# Assistant Language
# Supported: es (Spanish), en (English), fr (French)
ASSISTANT_LANGUAGE=es

# Temperature (0.0-1.0: lower=more deterministic, higher=more creative)
GROQ_TEMPERATURE=0.3

# Max tokens for response generation
GROQ_MAX_TOKENS=500

# ============================================================================
# LLM-FIRST MODE CONFIGURATION - TRAINING & PRODUCTION
# ============================================================================
# Control de cómo se generan las respuestas en el sistema
# Esta configuración determina si el sistema usa LLM o FSM para generar respuestas
#
# ESTRATEGIA DE 3 FASES:
# ------------------------------------------------------------------
# FASE 1 (Mes 1): LLM_FIRST_MODE=always
#   - Objetivo: Recolectar conversaciones reales para entrenar FSM
#   - TODO usa LLM (Cerebras/Gemini)
#   - Se registran TODAS las conversaciones
#   - Costo: ~$0.80 por 1,000 mensajes
#   - Resultado: 1,000+ conversaciones para entrenamiento
#
# FASE 2 (Mes 2): LLM_FIRST_MODE=hybrid
#   - Objetivo: Balancear costo y calidad
#   - FSM para intents comunes (80% de casos)
#   - LLM para intents complejos (20% de casos)
#   - Costo: ~$0.16 por 1,000 mensajes (-80%)
#   - Resultado: Sistema balanceado y eficiente
#
# FASE 3 (Mes 3+): LLM_FIRST_MODE=fallback
#   - Objetivo: Máxima eficiencia en producción
#   - FSM primero (95% de casos)
#   - LLM solo para casos no cubiertos (5%)
#   - Costo: ~$0.04 por 1,000 mensajes (-95%)
#   - Resultado: Sistema autónomo y escalable
# ------------------------------------------------------------------

# Modo LLM-First: "always", "hybrid", o "fallback"
LLM_FIRST_MODE=always

# Usar templates del FSM para respuestas
# false = Siempre usar LLM para generar respuestas (recomendado en Fase 1)
# true  = Usar templates FSM cuando sea posible (Fase 2 y 3)
USE_FSM_TEMPLATES=false

# Registrar TODAS las conversaciones para entrenamiento
# true  = Registra TODO (recomendado en Fase 1)
# false = Solo registra conversaciones exitosas
RECORD_ALL_CONVERSATIONS=true

# Umbral de confianza mínima para usar FSM templates (en modo hybrid)
# Solo se usa FSM si la clasificación tiene confianza >= este valor
# Rango: 0.0 - 1.0 (0.85 = 85% de confianza)
FSM_CONFIDENCE_THRESHOLD=0.85

# Intenciones que SIEMPRE usan LLM (separadas por comas, sin espacios)
# Estas son intenciones complejas que requieren razonamiento flexible
ALWAYS_LLM_INTENTS=complex_recommendation,handle_objection,negotiate,complaint,special_request

# Intenciones que pueden usar FSM templates (en modo hybrid, separadas por comas)
# Estas son intenciones simples con respuestas predecibles
FSM_ELIGIBLE_INTENTS=greeting,view_menu,view_category,add_to_order,confirm_order,goodbye

# ============================================================================
# MQTT (Message Broker)
# ============================================================================
MQTT_BROKER_HOST=mqtt
MQTT_BROKER_PORT=1883

# MQTT Credentials for each service
# Format: {service_name}_mqtt_user / {service_name}_mqtt_password
MQTT_USERNAME=restaurant_system
MQTT_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Service-specific MQTT credentials
ORDERS_MQTT_USER=orders_service
ORDERS_MQTT_PASSWORD=orders_service_password_CHANGE_IN_PROD

KITCHEN_MQTT_USER=kitchen_service
KITCHEN_MQTT_PASSWORD=kitchen_service_password_CHANGE_IN_PROD

WEBSOCKET_MQTT_USER=websocket_bridge
WEBSOCKET_MQTT_PASSWORD=websocket_bridge_password_CHANGE_IN_PROD

# MQTT Topics
MQTT_TOPIC_ORDERS=restaurant/orders
MQTT_TOPIC_KITCHEN=restaurant/kitchen
MQTT_TOPIC_TABLES=restaurant/tables
MQTT_TOPIC_STATUS=restaurant/status

# ============================================================================
# INFLUXDB (Time-Series Metrics Database)
# ============================================================================
INFLUX_USER=admin
INFLUX_PASSWORD=CHANGE_ME_IN_PRODUCTION_min16chars
INFLUX_TOKEN=GENERATE_WITH_openssl_rand_hex_32_CHANGE_IN_PRODUCTION

# InfluxDB Configuration
INFLUX_ORG=restaurant_system
INFLUX_BUCKET=restaurant_metrics
INFLUX_RETENTION=30d

# ============================================================================
# GRAFANA (Metrics Visualization)
# ============================================================================
# Default credentials (CHANGE IN PRODUCTION)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION_min12chars

# Grafana Configuration
GF_SECURITY_ADMIN_USER=${GRAFANA_ADMIN_USER}
GF_SECURITY_ADMIN_PASSWORD=${GRAFANA_ADMIN_PASSWORD}
GF_USERS_ALLOW_SIGN_UP=false

# ============================================================================
# SERVICE PORTS (Internal Docker Network)
# ============================================================================
# These are internal ports, DO NOT change unless you modify docker-compose.yml
MENU_SERVICE_PORT=5011
ORDERS_SERVICE_PORT=5012
TABLES_SERVICE_PORT=5013
AUTH_SERVICE_PORT=5014
REPORTS_SERVICE_PORT=5015
KITCHEN_SERVICE_PORT=5016
WEBSOCKET_BRIDGE_PORT=5018
VOICE_ASSISTANT_PORT=5000

# ============================================================================
# EXTERNAL PORTS (Host Machine)
# ============================================================================
# These are the ports exposed to your host machine
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
GRAFANA_PORT=3000
INFLUXDB_PORT=8086
MQTT_EXTERNAL_PORT=1883

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================
# Environment: development | staging | production
ENVIRONMENT=development

# Debug mode (NEVER enable in production)
DEBUG=true

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Allowed CORS origins (comma-separated)
# In production, replace * with specific domains
CORS_ORIGINS=*

# ============================================================================
# VOICE ASSISTANT CONFIGURATION
# ============================================================================
# Silence detection threshold (milliseconds)
SILENCE_THRESHOLD_MS=1500

# Max recording duration (seconds)
MAX_RECORDING_DURATION=30

# Audio format
AUDIO_FORMAT=wav
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# Voice Assistant Timeout Settings
STT_TIMEOUT=10
NLP_TIMEOUT=15
TTS_TIMEOUT=20
API_TIMEOUT=10

# ============================================================================
# WHATSAPP GATEWAY (Mesero Virtual por WhatsApp)
# ============================================================================

# Proveedor de WhatsApp: twilio o meta
WHATSAPP_PROVIDER=twilio

# -------------------------
# TWILIO CONFIGURATION
# -------------------------
# Get your credentials at: https://console.twilio.com/
# WhatsApp Sandbox: https://console.twilio.com/us1/develop/sms/try-it-out/whatsapp-learn
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_NUMBER=+14155238886

# -------------------------
# META CLOUD API CONFIGURATION
# -------------------------
# Setup at: https://developers.facebook.com/apps/
# WhatsApp Business API: https://developers.facebook.com/docs/whatsapp/cloud-api
META_PHONE_NUMBER_ID=your_phone_number_id_here
META_ACCESS_TOKEN=your_meta_access_token_here
META_VERIFY_TOKEN=mi_token_secreto_para_webhook

# ============================================================================
# UNIVERSAL POS MIDDLEWARE (Integración con POS externos)
# ============================================================================

# -------------------------
# DELIVERECT (50+ POS Systems)
# -------------------------
# Get your credentials at: https://dashboard.deliverect.com/
# Documentation: https://docs.deliverect.com/
DELIVERECT_API_URL=https://api.deliverect.com
DELIVERECT_CHANNEL_LINK_ID=your_channel_link_id_here
DELIVERECT_API_KEY=your_deliverect_api_key_here

# -------------------------
# SOFT RESTAURANT (Direct API)
# -------------------------
# Contact Soft Restaurant for API access
SOFT_RESTAURANT_URL=http://your-soft-restaurant-server:port
SOFT_RESTAURANT_API_KEY=your_soft_restaurant_api_key_here
SOFT_RESTAURANT_BRANCH_ID=1

# -------------------------
# OLACLICK (Direct API)
# -------------------------
# Get your credentials at: https://olaclick.com/
OLACLICK_API_URL=https://api.olaclick.com
OLACLICK_API_KEY=your_olaclick_api_key_here
OLACLICK_RESTAURANT_ID=your_restaurant_id_here

# ============================================================================
# CLOUDFLARE TUNNEL (Optional)
# ============================================================================
# For remote access via Cloudflare Tunnel
# Get token at: https://dash.cloudflare.com/
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================
# PostgreSQL backup settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups

# ============================================================================
# MONITORING & ALERTING
# ============================================================================
# Health check configuration
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3

# Alert thresholds
ALERT_ERROR_RATE_THRESHOLD=0.05      # 5% error rate
ALERT_RESPONSE_TIME_THRESHOLD=2000   # 2 seconds
ALERT_CPU_THRESHOLD=80               # 80% CPU usage
ALERT_MEMORY_THRESHOLD=85            # 85% memory usage

# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable features without code changes
FEATURE_VOICE_ASSISTANT=true
FEATURE_REAL_TIME_UPDATES=true
FEATURE_METRICS_COLLECTION=true
FEATURE_KITCHEN_DISPLAY=true
FEATURE_REPORTS=true

# ============================================================================
# CIRCUIT BREAKER CONFIGURATION
# ============================================================================
# Circuit breaker settings for external API calls
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60
CIRCUIT_BREAKER_EXPECTED_EXCEPTION=RequestException

# ============================================================================
# RATE LIMITING
# ============================================================================
# Rate limiting for API endpoints
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ============================================================================
# PRODUCTION CHECKLIST
# ============================================================================
# Before deploying to production, ensure you:
# ✅ Changed all default passwords and secrets
# ✅ Generated secure JWT_SECRET_KEY and SESSION_SECRET_KEY
# ✅ Set DEBUG=false
# ✅ Set ENVIRONMENT=production
# ✅ Configured specific CORS_ORIGINS (not *)
# ✅ Obtained and configured API keys:
#    - Deepgram (STT) - Required
#    - Groq (LLM) - Required
#    - Cartesia (TTS) - Recommended for ultra-fast voice (~90ms)
#    - ElevenLabs (TTS) - Alternative premium option
# ✅ Selected appropriate TTS voice for your restaurant's brand
# ✅ Enabled HTTPS with valid SSL certificates
# ✅ Configured backup strategy
# ✅ Set up monitoring and alerting
# ✅ Tested all features in staging environment
# ✅ Reviewed SECURITY_POLICY.md
# ✅ Reviewed RUNBOOK.md for operational procedures
#
# FOR WHATSAPP INTEGRATION:
# ✅ Configured Twilio OR Meta WhatsApp API credentials
# ✅ Set up webhook URL in provider dashboard:
#    - Twilio: https://your-domain.com/webhook/twilio
#    - Meta: https://your-domain.com/webhook/meta
# ✅ Verified webhook connectivity
#
# FOR POS INTEGRATION:
# ✅ Configured at least one POS adapter (Deliverect, Soft Restaurant, etc.)
# ✅ Tested order flow from WhatsApp to POS
# ✅ Verified menu sync between systems

# ============================================================================
# NOTES
# ============================================================================
# - Never commit the .env file to version control
# - Keep API keys secure and rotate them periodically
# - Monitor API usage to avoid exceeding free tier limits
# - ElevenLabs free tier: ~7 min/month (sufficient for testing)
# - For production, consider ElevenLabs Starter ($5/mo) or Creator ($22/mo)
# - Test different ElevenLabs voices to match your restaurant's brand
# - Use multilingual voices with language='es' for native Spanish sound
# - Adjust ELEVENLABS_STABILITY for desired expressiveness
# - Higher stability = more consistent, lower = more expressive/dynamic
