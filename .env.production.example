# ================================================================================
# PRODUCCIÓN - Variables de Entorno
# ================================================================================
# IMPORTANTE: NO subir este archivo con valores reales a Git
# Copiar a .env.production y completar con tus valores reales
# ================================================================================

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
PORT=8000

# ============================================================================
# URL BASE (CRÍTICO - Actualizar con tu URL de producción)
# ============================================================================
# Cloud Run: https://whatsapp-gateway-xxxxx-uc.a.run.app
# Railway: https://whatsapp-gateway-production.up.railway.app
# Render: https://whatsapp-gateway-xxxx.onrender.com
# Firebase: https://whatsapp-saas-prod.web.app
BASE_URL=https://tu-url-de-produccion.com

# ============================================================================
# WHATSAPP - TWILIO (PRODUCCIÓN)
# ============================================================================
WHATSAPP_PROVIDER=twilio

# IMPORTANTE: Usar número de producción, NO sandbox
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+5215512345678

# ============================================================================
# WHATSAPP - META CLOUD API (ALTERNATIVA)
# ============================================================================
# Si prefieres usar Meta en lugar de Twilio, cambia WHATSAPP_PROVIDER=meta
META_PHONE_NUMBER_ID=123456789012345
META_ACCESS_TOKEN=EAAbVnXXXXXXXXXXXXXXXXXXXX
META_VERIFY_TOKEN=tu_token_verificacion_meta_2025

# ============================================================================
# AI PROVIDERS - LLM (Mínimo 1 requerido)
# ============================================================================

# CEREBRAS (Llama 3.3 70B) - Recomendado, GRATIS
CEREBRAS_API_KEY=csk-xxxxxxxxxxxxxxxxxxxxxxxxxx

# GROQ (Llama 3.1 8B) - Fallback, GRATIS
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxx

# GOOGLE GEMINI (Gemini 2.0 Flash) - Alternativa
GOOGLE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPENAI (GPT-4o) - Premium fallback
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# VOICE PROVIDERS (OPCIONAL - Solo si usas audio)
# ============================================================================

# DEEPGRAM (Speech-to-Text) - Para notas de voz
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx

# CARTESIA (Text-to-Speech) - Ultra rápido
CARTESIA_API_KEY=sk_car_xxxxxxxxxxxxxxxxxx
CARTESIA_VOICE_ID=846d6cb0-2301-48b6-9683-48f5618ea2f6

# ELEVENLABS (Text-to-Speech) - Alternativa premium
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ============================================================================
# DATABASE - PostgreSQL (RECOMENDADO PARA PRODUCCIÓN)
# ============================================================================
# Cloud SQL, Supabase, Railway DB, Render DB, etc.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Alternativa: Firestore (Google Cloud)
USE_FIRESTORE=false
GCP_PROJECT_ID=tu-proyecto-gcp

# ============================================================================
# REDIS (IMPORTANTE - Para sesiones en producción)
# ============================================================================
# Cloud Memorystore, Upstash, Railway Redis, Render Redis, etc.
REDIS_URL=redis://default:password@host:6379
REDIS_HOST=tu-redis-host.com
REDIS_PORT=6379
REDIS_PASSWORD=tu-password-redis
REDIS_DB=0
REDIS_TLS=true

# ============================================================================
# SECURITY (CRÍTICO - Generar valores únicos)
# ============================================================================
# Generar con: openssl rand -hex 32
JWT_SECRET=genera_un_valor_unico_de_64_caracteres_minimo_aqui_12345678
SESSION_SECRET_KEY=genera_otro_valor_unico_diferente_al_anterior_87654321

# ============================================================================
# CORS (Permitir dominios específicos en producción)
# ============================================================================
# Separar múltiples orígenes con comas
CORS_ORIGINS=https://tu-frontend.com,https://www.tu-frontend.com,https://admin.tu-frontend.com

# ============================================================================
# PAGOS (OPCIONAL - Según tus necesidades)
# ============================================================================

# Stripe
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# MONITOREO Y ANALYTICS (OPCIONAL)
# ============================================================================

# Sentry (Monitoreo de errores)
SENTRY_DSN=https://xxxxxxxxxx@sentry.io/xxxxxxx

# Google Analytics
GA_TRACKING_ID=G-XXXXXXXXXX

# ============================================================================
# EMAIL (OPCIONAL - Para notificaciones)
# ============================================================================

# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@tudominio.com

# ============================================================================
# CLOUDFLARE (OPCIONAL - Si usas sus servicios)
# ============================================================================
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# BACKUP Y STORAGE (OPCIONAL)
# ============================================================================

# Google Cloud Storage
GCS_BUCKET_NAME=whatsapp-saas-prod-backups
GCS_CREDENTIALS_PATH=/app/gcs-credentials.json

# AWS S3
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_S3_BUCKET=whatsapp-saas-prod

# ============================================================================
# RATE LIMITING (Recomendado para producción)
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ============================================================================
# FEATURES FLAGS (Opcional)
# ============================================================================
ENABLE_DEMO_MODE=true
ENABLE_LOYALTY_SYSTEM=true
ENABLE_VOICE_MESSAGES=true
ENABLE_ANALYTICS=true
