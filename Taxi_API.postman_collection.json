{
	"info": {
		"_postman_id": "taxi-api-collection-v1",
		"name": "Taxi System API",
		"description": "Collection completa de endpoints para el sistema de gestión de taxis\n\n**Variables de entorno requeridas:**\n- `base_url`: URL base del API\n- `token`: Token JWT de autenticación\n- `tenant_id`: ID del tenant\n- `driver_id`: ID del conductor (se autocompleta)\n- `customer_id`: ID del cliente (se autocompleta)\n- `ride_id`: ID del viaje (se autocompleta)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login Driver",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const response = pm.response.json();",
									"    pm.environment.set('token', response.token);",
									"    pm.environment.set('driver_id', response.user.id);",
									"    pm.test('Token guardado correctamente', true);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"phone\": \"+525512345678\",\n  \"password\": \"driver123\",\n  \"user_type\": \"driver\",\n  \"tenant_id\": \"{{tenant_id}}\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/auth/login",
							"host": ["{{base_url}}"],
							"path": ["auth", "login"]
						}
					}
				},
				{
					"name": "Login Customer",
					"event": [
						{
							"listen": "test",
