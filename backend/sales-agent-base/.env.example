# ================================
# WHATSAPP SAAS - Configuración de Variables de Entorno
# ================================
# Copia este archivo a .env y configura tus valores reales

# ================================
# TWILIO (WhatsApp API)
# ================================
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=+14155238886

# ================================
# GOOGLE MAPS API (Para servicio de Taxi)
# ================================
# Requerido para: tenant_taxi_001
# Obtén tu API key en: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# APIs habilitadas requeridas:
# - Directions API
# - Geocoding API
# - Distance Matrix API
# - Places API
# - Roads API

# ================================
# BASE DE DATOS (PostgreSQL)
# ================================
DATABASE_URL=postgresql://user:password@localhost:5432/whatsapp_saas
DB_HOST=localhost
DB_PORT=5432
DB_NAME=whatsapp_saas
DB_USER=postgres
DB_PASSWORD=your_password_here

# ================================
# REDIS (Para caché y sesiones)
# ================================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ================================
# CHROMADB (Para RAG - Farmacia)
# ================================
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_PERSIST_DIRECTORY=./data/chroma

# ================================
# OPENAI / ANTHROPIC (Para LLM)
# ================================
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ================================
# STRIPE (Pagos digitales para Taxi)
# ================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ================================
# SERVIDOR
# ================================
PORT=8096
HOST=0.0.0.0
ENVIRONMENT=development  # development, staging, production
DEBUG=true
LOG_LEVEL=INFO

# ================================
# FRONTEND URLs
# ================================
CUSTOMER_APP_URL=http://localhost:3000
ADMIN_PANEL_URL=http://localhost:3001
DRIVER_APP_URL=http://localhost:3002

# ================================
# SEGURIDAD
# ================================
SECRET_KEY=your_secret_key_here_change_in_production
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRATION_HOURS=24

# ================================
# NOTIFICACIONES
# ================================
# SMS (Twilio también para SMS)
TWILIO_SMS_NUMBER=+1234567890

# Email (SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
FROM_EMAIL=noreply@tudominio.com

# Push Notifications (Firebase)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY_PATH=./config/firebase-key.json

# ================================
# WEBHOOKS
# ================================
WEBHOOK_BASE_URL=https://your-domain.com  # URL pública para recibir webhooks
WEBHOOK_SECRET=your_webhook_secret_here

# ================================
# STORAGE (Para fotos de productos, perfiles, etc.)
# ================================
STORAGE_TYPE=local  # local, s3, gcs
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# ================================
# MONITORING & ANALYTICS
# ================================
SENTRY_DSN=your_sentry_dsn_here
GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X

# ================================
# CONFIGURACIÓN POR TENANT
# ================================
DEFAULT_TENANT_ID=rico-mar-salvatierra
TENANTS_CONFIG_PATH=./config/tenants.json

# ================================
# CARACTERÍSTICAS
# ================================
ENABLE_VOICE_RECOGNITION=false
ENABLE_RAG_SEARCH=true
ENABLE_REAL_TIME_TRACKING=true
ENABLE_PAYMENT_PROCESSING=true

# ================================
# LIMITES Y QUOTAS
# ================================
MAX_REQUESTS_PER_MINUTE=60
MAX_FILE_UPLOAD_SIZE_MB=10
SESSION_TIMEOUT_MINUTES=30

# ================================
# DESARROLLO Y TESTING
# ================================
TEST_PHONE_NUMBER=+5215500000000
TEST_CUSTOMER_PHONE=+5215511111111
TEST_DRIVER_PHONE=+5215522222222

# Para testing sin APIs reales
MOCK_GOOGLE_MAPS=false
MOCK_TWILIO=false
MOCK_STRIPE=false

# ================================
# NOTAS IMPORTANTES
# ================================
# 1. NUNCA subas el archivo .env a Git
# 2. En producción, usa valores seguros y diferentes
# 3. Guarda las credenciales en un gestor de secretos (AWS Secrets Manager, etc.)
# 4. Rota las claves periódicamente
# 5. Google Maps API: Habilita facturación para evitar límites
