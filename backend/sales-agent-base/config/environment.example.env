# ============================================================
# CONFIGURACIÓN DE ENTORNO - ASISTENTE DE VOZ CON LLM
# ============================================================
# Proyecto: RESTAURANT_VOICE_SYSTEM_2.0
# Archivo: environment.example.env
# Descripción: Variables de entorno para configuración del sistema
# ============================================================
#
# INSTRUCCIONES:
# 1. Copia este archivo a .env
# 2. Completa los valores según tu configuración
# 3. NO compartas el archivo .env (ya está en .gitignore)
# ============================================================

# ------------------------------------------------------------
# CONFIGURACIÓN GENERAL DEL RESTAURANTE
# ------------------------------------------------------------

RESTAURANT_NAME="Mi Restaurante"
RESTAURANT_TIMEZONE="America/Mexico_City"
RESTAURANT_CURRENCY="MXN"
RESTAURANT_LANGUAGE="es-MX"

# ------------------------------------------------------------
# CONFIGURACIÓN DEL LLM (MODELO DE LENGUAJE)
# ------------------------------------------------------------

# Tipo de LLM: "local" o "cloud"
LLM_TYPE="local"

# Para LLM LOCAL (Ollama, LM Studio, etc.)
LLM_LOCAL_ENDPOINT="http://localhost:11434"
LLM_LOCAL_MODEL="llama3:8b"
LLM_LOCAL_CONTEXT_LENGTH=4096
LLM_LOCAL_TEMPERATURE=0.7
LLM_LOCAL_TOP_P=0.9
LLM_LOCAL_TOP_K=40

# Para LLM CLOUD (OpenAI, Anthropic, etc.)
LLM_CLOUD_PROVIDER="openai"  # openai, anthropic, cohere, etc.
LLM_CLOUD_API_KEY="your-api-key-here"
LLM_CLOUD_MODEL="gpt-4"
LLM_CLOUD_ENDPOINT="https://api.openai.com/v1"
LLM_CLOUD_MAX_TOKENS=500
LLM_CLOUD_TEMPERATURE=0.7

# Configuración común de LLM
LLM_MAX_RESPONSE_LENGTH=150  # caracteres
LLM_TIMEOUT_SECONDS=10
LLM_RETRY_ATTEMPTS=3

# ------------------------------------------------------------
# CONFIGURACIÓN DE VOZ (SPEECH-TO-TEXT)
# ------------------------------------------------------------

# Proveedor STT: "whisper", "google", "azure", "deepgram"
STT_PROVIDER="whisper"

# Para Whisper (Local)
WHISPER_MODEL_SIZE="base"  # tiny, base, small, medium, large
WHISPER_LANGUAGE="es"
WHISPER_DEVICE="cpu"  # cpu o cuda
WHISPER_COMPUTE_TYPE="int8"

# Para Google Cloud STT
GOOGLE_STT_API_KEY="your-google-api-key"
GOOGLE_STT_LANGUAGE="es-MX"

# Para Azure STT
AZURE_STT_KEY="your-azure-key"
AZURE_STT_REGION="eastus"
AZURE_STT_LANGUAGE="es-MX"

# Configuración común de STT
STT_SAMPLE_RATE=16000
STT_AUDIO_FORMAT="wav"
STT_ENABLE_NOISE_REDUCTION=true

# ------------------------------------------------------------
# CONFIGURACIÓN DE VOZ (TEXT-TO-SPEECH)
# ------------------------------------------------------------

# Proveedor TTS: "elevenlabs", "piper", "google", "azure"
TTS_PROVIDER="piper"

# Para ElevenLabs
ELEVENLABS_API_KEY="your-elevenlabs-api-key"
ELEVENLABS_VOICE_ID="voice-id-here"
ELEVENLABS_MODEL_ID="eleven_multilingual_v2"
ELEVENLABS_STABILITY=0.5
ELEVENLABS_SIMILARITY_BOOST=0.75

# Para Piper (Local)
PIPER_MODEL_PATH="/models/piper/es_MX-claude-medium.onnx"
PIPER_SPEAKER_ID=0
PIPER_SPEED=1.0

# Para Google Cloud TTS
GOOGLE_TTS_API_KEY="your-google-api-key"
GOOGLE_TTS_LANGUAGE="es-MX"
GOOGLE_TTS_VOICE="es-MX-Standard-A"

# Configuración común de TTS
TTS_SPEECH_RATE=1.0  # 0.5 a 2.0
TTS_PITCH=0  # -20 a 20
TTS_VOLUME=0  # -20 a 20
TTS_AUDIO_FORMAT="mp3"
TTS_SAMPLE_RATE=24000

# ------------------------------------------------------------
# CONFIGURACIÓN DE ARCHIVOS DE CONOCIMIENTO
# ------------------------------------------------------------

MENU_KNOWLEDGE_PATH="./config/menu_knowledge.json"
SALES_RULES_PATH="./config/sales_rules.yaml"
ASSISTANT_PROMPTS_PATH="./config/assistant_prompts.yaml"

# Actualización automática de archivos
AUTO_RELOAD_CONFIG=true
CONFIG_RELOAD_INTERVAL_SECONDS=300  # 5 minutos

# ------------------------------------------------------------
# CONFIGURACIÓN DE BASE DE DATOS
# ------------------------------------------------------------

# Base de datos para historial de conversaciones y órdenes
DB_TYPE="postgresql"  # postgresql, mysql, mongodb
DB_HOST="localhost"
DB_PORT=5432
DB_NAME="restaurant_voice_db"
DB_USER="postgres"
DB_PASSWORD="your-db-password"
DB_POOL_SIZE=10

# ------------------------------------------------------------
# CONFIGURACIÓN DE REDIS (CACHÉ Y SESIONES)
# ------------------------------------------------------------

REDIS_ENABLED=true
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

# Tiempo de vida de sesiones de conversación
CONVERSATION_SESSION_TTL_SECONDS=300  # 5 minutos

# ------------------------------------------------------------
# CONFIGURACIÓN DE LOGS
# ------------------------------------------------------------

LOG_LEVEL="info"  # debug, info, warning, error, critical
LOG_FORMAT="json"  # json, text
LOG_OUTPUT="file"  # console, file, both
LOG_FILE_PATH="./logs/voice-assistant.log"
LOG_MAX_FILE_SIZE_MB=10
LOG_BACKUP_COUNT=5

# Logs de conversaciones
CONVERSATION_LOGGING_ENABLED=true
CONVERSATION_LOG_PATH="./logs/conversations/"
SAVE_AUDIO_RECORDINGS=false  # Privacidad: guardar audios originales

# ------------------------------------------------------------
# CONFIGURACIÓN DE MÉTRICAS Y ANALYTICS
# ------------------------------------------------------------

METRICS_ENABLED=true
METRICS_PROVIDER="prometheus"  # prometheus, datadog, custom
METRICS_PORT=9090

# Métricas a trackear
TRACK_RESPONSE_TIME=true
TRACK_UPSELL_RATE=true
TRACK_AVERAGE_TICKET=true
TRACK_CUSTOMER_SATISFACTION=true

# ------------------------------------------------------------
# CONFIGURACIÓN DE SEGURIDAD
# ------------------------------------------------------------

# Autenticación
ENABLE_AUTHENTICATION=false
API_KEY="your-secure-api-key-here"
JWT_SECRET="your-jwt-secret-here"
JWT_EXPIRATION_HOURS=24

# Rate limiting
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# CORS
CORS_ENABLED=true
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# ------------------------------------------------------------
# CONFIGURACIÓN DE CARACTERÍSTICAS DEL ASISTENTE
# ------------------------------------------------------------

# Funcionalidades habilitadas
ENABLE_UPSELLING=true
ENABLE_PROMOTIONS=true
ENABLE_PERSONALIZATION=true
ENABLE_ORDER_HISTORY=false

# Límites de comportamiento
MAX_UPSELL_ATTEMPTS=2
MAX_CONVERSATION_TURNS=20
MAX_ORDER_ITEMS=15

# Contexto de conversación
CONVERSATION_CONTEXT_WINDOW=10  # últimas N interacciones
REMEMBER_CUSTOMER_PREFERENCES=true

# ------------------------------------------------------------
# CONFIGURACIÓN DE INTEGRACIÓN CON OTROS SERVICIOS
# ------------------------------------------------------------

# Servicio de Menú
MENU_SERVICE_URL="http://localhost:3001/api/menu"
MENU_SERVICE_TIMEOUT_MS=5000

# Servicio de Órdenes
ORDERS_SERVICE_URL="http://localhost:3002/api/orders"
ORDERS_SERVICE_TIMEOUT_MS=5000

# Servicio de Notificaciones
NOTIFICATIONS_SERVICE_URL="http://localhost:3003/api/notifications"
ENABLE_ORDER_NOTIFICATIONS=true

# ------------------------------------------------------------
# CONFIGURACIÓN DE DESARROLLO
# ------------------------------------------------------------

# Entorno
NODE_ENV="development"  # development, production, test
DEBUG_MODE=true

# Testing
ENABLE_TEST_MODE=false
MOCK_LLM_RESPONSES=false
MOCK_VOICE_SERVICES=false

# ------------------------------------------------------------
# CONFIGURACIÓN DE PRODUCCIÓN
# ------------------------------------------------------------

# Performance
ENABLE_RESPONSE_CACHING=true
CACHE_TTL_SECONDS=60
ENABLE_COMPRESSION=true

# Monitoreo
ENABLE_HEALTH_CHECKS=true
HEALTH_CHECK_PORT=8080
HEALTH_CHECK_INTERVAL_SECONDS=30

# Alertas
ENABLE_ALERTS=false
ALERT_EMAIL="admin@restaurant.com"
ALERT_WEBHOOK_URL=""

# Backup automático
ENABLE_AUTO_BACKUP=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30

# ------------------------------------------------------------
# CONFIGURACIÓN AVANZADA
# ------------------------------------------------------------

# Optimización de LLM
ENABLE_PROMPT_CACHING=true
ENABLE_STREAMING_RESPONSES=false
BATCH_SIZE=1

# Análisis de sentimiento
ENABLE_SENTIMENT_ANALYSIS=false
SENTIMENT_THRESHOLD_NEGATIVE=0.3

# Feedback automático
ENABLE_AUTO_FEEDBACK_COLLECTION=true
ASK_FEEDBACK_EVERY_N_ORDERS=5

# ============================================================
# FIN DE CONFIGURACIÓN
# ============================================================
