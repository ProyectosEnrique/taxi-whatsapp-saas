"""
================================================================================
VOICE RESTAURANT ASSISTANT - TTS HANDLER v2.0
================================================================================
Wrapper para Text-to-Speech usando ElevenLabs API
Voz ultra-natural con soporte multilingüe
================================================================================
"""

from pathlib import Path
import logging
import os
import httpx
from typing import Optional

logger = logging.getLogger(__name__)


class TTSHandler:
    """
    Handler para Text-to-Speech usando ElevenLabs API

    Features:
    - Voz ultra-natural (+58% calidad vs gTTS)
    - Soporte multilingüe nativo
    - Configuración de estabilidad y similitud
    - Fallback a gTTS si ElevenLabs falla
    """

    def __init__(
        self,
        api_key: Optional[str] = None,
        voice_id: str = "21m00Tcm4TlvDq8ikWAM",  # Rachel (default)
        model: str = "eleven_multilingual_v2",
        stability: float = 0.5,
        similarity_boost: float = 0.75,
        lang: str = "es"
    ):
        """
        Inicializar TTS Handler

        Args:
            api_key: ElevenLabs API key (si None, usa env var)
            voice_id: ID de la voz a usar
            model: Modelo de ElevenLabs
            stability: Control de estabilidad (0.0-1.0)
            similarity_boost: Similitud con voz original (0.0-1.0)
            lang: Idioma (para fallback gTTS)
        """
        self.api_key = api_key or os.getenv("ELEVENLABS_API_KEY")
        self.voice_id = voice_id
        self.model = model
        self.stability = stability
        self.similarity_boost = similarity_boost
        self.lang = lang

        # ElevenLabs API endpoint
        self.base_url = "https://api.elevenlabs.io/v1"

        # Verificar si tenemos API key
        self.use_elevenlabs = bool(self.api_key and self.api_key != "tu_elevenlabs_api_key_aqui")

        if self.use_elevenlabs:
            logger.info(
                f"TTSHandler inicializado con ElevenLabs "
                f"(voice_id={voice_id}, model={model})"
            )
        else:
            logger.warning(
                "ElevenLabs API key no configurada, usando gTTS como fallback"
            )

    async def synthesize_to_file(self, text: str, output_path: Path) -> bool:
        """
        Sintetizar texto a archivo de audio

        Args:
            text: Texto a sintetizar
            output_path: Ruta del archivo de salida

        Returns:
            True si exitoso
        """
        if self.use_elevenlabs:
            try:
                return await self._synthesize_elevenlabs(text, output_path)
            except Exception as e:
                logger.error(f"Error en ElevenLabs: {e}, fallback a gTTS")
                return self._synthesize_gtts(text, output_path)
        else:
            return self._synthesize_gtts(text, output_path)

    async def _synthesize_elevenlabs(self, text: str, output_path: Path) -> bool:
        """
        Sintetizar usando ElevenLabs API
        """
        url = f"{self.base_url}/text-to-speech/{self.voice_id}"

        headers = {
            "Accept": "audio/mpeg",
            "Content-Type": "application/json",
            "xi-api-key": self.api_key
        }

        data = {
            "text": text,
            "model_id": self.model,
            "voice_settings": {
                "stability": self.stability,
                "similarity_boost": self.similarity_boost
            }
        }

        async with httpx.AsyncClient(timeout=30.0) as client:
            response = await client.post(url, json=data, headers=headers)

            if response.status_code == 200:
                # Guardar audio a archivo
                output_path.parent.mkdir(parents=True, exist_ok=True)
                with open(output_path, "wb") as f:
                    f.write(response.content)

                logger.info(
                    f"Audio ElevenLabs generado: {output_path} "
                    f"({len(response.content)} bytes)"
                )
                return True
            else:
                error_msg = response.text
                logger.error(
                    f"ElevenLabs API error: {response.status_code} - {error_msg}"
                )

                # Si es error de cuota, log específico
                if response.status_code == 401:
                    logger.error("API key inválida o expirada")
                elif response.status_code == 429:
                    logger.error("Rate limit excedido o cuota agotada")

                return False

    def _synthesize_gtts(self, text: str, output_path: Path) -> bool:
        """
        Sintetizar usando gTTS (fallback)
        """
        try:
            from gtts import gTTS

            tts = gTTS(text=text, lang=self.lang, tld="es")
            tts.save(str(output_path))

            logger.info(f"Audio gTTS generado (fallback): {output_path}")
            return True
        except Exception as e:
            logger.error(f"Error en gTTS: {e}")
            return False

    def synthesize_to_file_sync(self, text: str, output_path: Path) -> bool:
        """
        Versión síncrona para compatibilidad con código legacy
        """
        import asyncio

        try:
            loop = asyncio.get_event_loop()
        except RuntimeError:
            loop = asyncio.new_event_loop()
            asyncio.set_event_loop(loop)

        return loop.run_until_complete(self.synthesize_to_file(text, output_path))


# Instancia global
_tts_handler = None


def get_tts_handler():
    """Obtener instancia global del TTSHandler (Singleton)"""
    global _tts_handler
    if _tts_handler is None:
        from ..core.config import settings

        # Leer configuración de ElevenLabs
        elevenlabs_api_key = getattr(settings, 'ELEVENLABS_API_KEY', None)
        voice_id = getattr(settings, 'ELEVENLABS_VOICE_ID', '21m00Tcm4TlvDq8ikWAM')
        model = getattr(settings, 'ELEVENLABS_MODEL', 'eleven_multilingual_v2')
        stability = float(getattr(settings, 'ELEVENLABS_STABILITY', 0.5))
        similarity_boost = float(getattr(settings, 'ELEVENLABS_SIMILARITY_BOOST', 0.75))
        lang = settings.ASSISTANT_VOICE_LANG

        _tts_handler = TTSHandler(
            api_key=elevenlabs_api_key,
            voice_id=voice_id,
            model=model,
            stability=stability,
            similarity_boost=similarity_boost,
            lang=lang
        )
    return _tts_handler
