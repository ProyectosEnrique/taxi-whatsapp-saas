rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Tiendas (multi-tenant)
    match /stores/{storeId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.owner;
      allow write: if request.auth != null && request.auth.uid == request.resource.data.owner;
    }

    // Productos por tienda
    match /stores/{storeId}/products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && get(/databases/$(database)/documents/stores/$(storeId)).data.owner == request.auth.uid;
    }

    // Pedidos
    match /stores/{storeId}/orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update: if request.auth != null;
    }
  }
}
