rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /stores/{storeId}/products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /stores/{storeId}/logos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
